{
  "project": "JSON Formatter Pro",
  "version": "2.0.0",
  "features": {
    "uiux": {
      "designSystem": "UI/UX Pro Max",
      "animations": {
        "spring": {
          "stiffness": 400,
          "damping": 30,
          "mass": 0.8
        },
        "durations": {
          "microInteraction": "150-200ms",
          "expandCollapse": "250ms",
          "exit": "200ms"
        },
        "easing": [0.4, 0, 0.2, 1]
      },
      "colors": {
        "keys": "purple-600",
        "strings": "green-600",
        "numbers": "orange-600",
        "booleans": "blue-600",
        "null": "red-600"
      },
      "accessibility": {
        "contrast": "4.5:1",
        "touchTargets": "44x44pt",
        "focusRings": "2px visible",
        "ariaLabels": true
      }
    },
    "interactions": {
      "collapsible": true,
      "staggeredAnimation": true,
      "hoverEffects": ["scale", "translateY", "shadow"],
      "feedbackTime": "< 100ms"
    },
    "designStandards": [
      "Apple Human Interface Guidelines",
      "Material Design 3",
      "WCAG 2.1 AA",
      "UI/UX Pro Max 161 Rules"
    ]
  },
  "techStack": {
    "framework": "Next.js 16.2",
    "language": "TypeScript",
    "styling": "Tailwind CSS 4.0",
    "animation": "Framer Motion",
    "icons": "Lucide React"
  },
  "performance": {
    "fps": 60,
    "interactionLatency": "80-100ms",
    "animationDuration": "150-250ms",
    "toastDuration": "3s"
  },
  "highlights": [
    "Spring physics animations",
    "Glassmorphism effects",
    "Gradient magic",
    "Micro-interactions",
    "Semantic colors",
    "Responsive design",
    "Dark mode support",
    "Accessibility first"
  ],
  "stats": {
    "totalAnimations": 25,
    "colorVariants": 10,
    "shadowLevels": 5,
    "borderRadiusOptions": 4,
    "responsive": true
  }
}
